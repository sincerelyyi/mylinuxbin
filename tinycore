#!/usr/bin/bash
#file name: tinycore
#open virtalmachine tinycore  and ssh on it
domstate="$(virsh domstate tinycore)"
case "$domstate" in
"shut off")
    echo tinycore is starting...
    virsh start tinycore
    ;;
"running")
    echo "tinycore have being running"
    ;;
*)
    echo "domstate=${domstate}"
    echo "have some errors"
    exit
    ;;
esac

timeout=0
while ! nc -zw1 tinycore 22 >/dev/null 2>&1;do
    echo -n '.'
    let timeout++
    if [ "$timeout" -gt 60 ];then
        echo ""
        echo "connecting timeout."
        exit
    fi
done
echo -e "\n\n"
sshpass -p zjy85295675 ssh  tc@tinycore
